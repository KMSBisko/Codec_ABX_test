# Codec ABX Web Server - Environment Configuration
# Copy this file to .env and customize for your deployment

# Flask Environment
FLASK_ENV=development
FLASK_DEBUG=0

# Server Configuration
PORT=5000
FLASK_SECRET_KEY=dev-insecure-key-change-in-production

# Audio Processing
MAX_FILE_SIZE=524288000  # 500MB in bytes
TEMP_DIR=/tmp/abx_web

# ffmpeg paths (usually auto-detected from PATH)
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# Session Configuration
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Upload Configuration
UPLOAD_FOLDER=web/uploads
SESSIONS_FOLDER=web/sessions

# Optional: Database backend (future feature)
# DATABASE_URL=postgresql://user:password@localhost/codec_abx
